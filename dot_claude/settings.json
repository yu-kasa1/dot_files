{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)"
    ],
    "deny": [
      "Bash(git commit :*)",
      "Bash(git push :*)",
      "Bash(git merge :*)",
      "Bash(git rebase :*)",
      "Bash(git reset --hard :*)",
      "Bash(rm -rf /*)",
      "Bash(rm :*)",
      "Bash(sed -i :*)",
      "Bash(mv :*)",
      "Bash(cp -f :*)",
      "Bash(sudo :*)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(cat .env*)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/prompt-rule-inject.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-cat-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-explain-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-rule-inject.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/edit-retry-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/edit-retry-guard.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(basename \"$PWD\") && osascript -e \"display notification \\\"[$REPO] 確認が必要です\\\" with title \\\"Claude Code\\\" sound name \\\"Ping\\\"\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(basename \"$PWD\") && osascript -e \"display notification \\\"[$REPO] 権限の確認が必要です\\\" with title \\\"Claude Code\\\" sound name \\\"Ping\\\"\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(basename \"$PWD\") && osascript -e \"display notification \\\"[$REPO] 処理が完了しました\\\" with title \\\"Claude Code\\\" sound name \\\"Glass\\\"\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%s | ctx: %.0f%%\" \"$model\" \"$used\"; else printf \"%s\" \"$model\"; fi"
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "model": "claude-opus-4-7[1m]"
}
