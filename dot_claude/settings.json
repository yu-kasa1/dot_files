{
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://127.0.0.1:4318",
    "OTEL_METRIC_EXPORT_INTERVAL": "60000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000",
    "OTEL_RESOURCE_ATTRIBUTES": "user.email=y.kasai,instance.id=MBL562N.local"
  },
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(awk:*)",
      "Bash(tree:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(git show:*)",
      "Bash(git grep:*)",
      "Bash(git blame:*)",
      "Bash(git branch:*)",
      "Read(//Users/y.kasai/develop/**)",
      "Read(//Users/y.kasai/dot_files/**)"
    ],
    "deny": [
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset --hard:*)",
      "Bash(git -*)",
      "Bash(rm:*)",
      "Bash(sed -i:*)",
      "Bash(mv:*)",
      "Bash(cp -f:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(cat .env*)"
    ]
  },
  "model": "claude-opus-4-7[1m]",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/prompt-rule-inject.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-cat-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-explain-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-env-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-secret-file-guard.sh\""
          },
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/bash-db-dml-guard.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/pretool-rule-inject.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/edit-retry-guard.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(basename \"$PWD\") && osascript -e \"display notification \\\"[$REPO] 確認が必要です\\\" with title \\\"Claude Code\\\" sound name \\\"Ping\\\"\""
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(basename \"$PWD\") && osascript -e \"display notification \\\"[$REPO] 権限の確認が必要です\\\" with title \\\"Claude Code\\\" sound name \\\"Ping\\\"\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "REPO=$(basename \"$PWD\") && osascript -e \"display notification \\\"[$REPO] 処理が完了しました\\\" with title \\\"Claude Code\\\" sound name \\\"Glass\\\"\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "input=$(cat); model=$(echo \"$input\" | jq -r '.model.display_name'); used=$(echo \"$input\" | jq -r '.context_window.used_percentage // empty'); if [ -n \"$used\" ]; then printf \"%s | ctx: %.0f%%\" \"$model\" \"$used\"; else printf \"%s\" \"$model\"; fi"
  },
  "enabledPlugins": {
    "plugin-dev@claude-plugins-official": true
  },
  "language": "Japanese",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true
}
